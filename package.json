{
  "name": "react-native-universal-modal",
  "version": "1.0.0",
  "description": "A fully customizable, accessible, cross-platform modal system for React Native (iOS, Android, Web)",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js",
      "types": "./lib/typescript/index.d.ts"
    },
    "./animations": {
      "import": "./lib/module/animation/index.js",
      "require": "./lib/commonjs/animation/index.js",
      "types": "./lib/typescript/animation/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf lib",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck"
  },
  "keywords": [
    "react-native",
    "modal",
    "dialog",
    "popup",
    "overlay",
    "accessibility",
    "a11y",
    "cross-platform",
    "ios",
    "android",
    "web",
    "react-native-web",
    "expo",
    "typescript",
    "animation",
    "reanimated",
    "focus-trap",
    "nested-modals"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/react-native-universal-modal"
  },
  "bugs": {
    "url": "https://github.com/yourusername/react-native-universal-modal/issues"
  },
  "homepage": "https://github.com/yourusername/react-native-universal-modal#readme",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0"
  },
  "peerDependenciesMeta": {
    "react-native-reanimated": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "react": "^18.2.0",
    "react-native": "^0.73.0",
    "react-test-renderer": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
